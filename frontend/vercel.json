{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/route.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/audit",
      "dest": "backend/route.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
